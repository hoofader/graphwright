{
  "name": "graphwright",
  "version": "0.1.0",
  "description": "Entity extraction and incremental knowledge-graph maintenance with a human-in-the-loop mention model. Storage-agnostic, LLM-provider-agnostic, TypeScript-native.",
  "license": "Apache-2.0",
  "author": "Hoofader",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoofader/graphwright.git"
  },
  "keywords": [
    "knowledge-graph",
    "entity-extraction",
    "entity-resolution",
    "ner",
    "llm",
    "human-in-the-loop",
    "bitemporal"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.19.20",
    "@types/pg": "^8.20.0",
    "eslint": "^9.18.0",
    "pg": "^8.22.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
